<?xml version="1.0" encoding="utf-8"?>
<registry>

  <records interface="Products.CMFPlone.interfaces.IBundleRegistry"
           prefix="plone.bundles/plone-palette">
    <value key="enabled">True</value>
    <!-- load only for logged-in users; non-managers are logged-in but the
         customizer form never enters the DOM for them, so the script is inert -->
    <value key="expression">python: member is not None</value>
    <value key="jscompilation">++plone++plone.palette/customizer.js</value>
    <value key="csscompilation"></value>
    <value key="load_async">False</value>
    <value key="load_defer">True</value>
    <value key="depends">plone</value>
  </records>

</registry>
